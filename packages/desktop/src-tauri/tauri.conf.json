{
  "productName": "Babelr",
  "version": "0.1.0",
  "identifier": "com.babelr.app",
  "build": {
    "frontendDist": "../../client/dist",
    "devUrl": "http://localhost:1111",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Babelr",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: wss: ws: http:; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' blob:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["babelr"]
      }
    },
    "shell": {
      "open": true
    }
  }
}
