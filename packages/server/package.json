{
  "name": "@babelr/server",
  "version": "0.1.0",
  "private": true,
  "license": "Hippocratic-3.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/server.js",
    "db:generate": "drizzle-kit --env-file=../../.env generate",
    "db:migrate": "drizzle-kit --env-file=../../.env migrate",
    "benchmark": "tsx --env-file=../../.env src/benchmark/cli.ts"
  },
  "dependencies": {
    "@babelr/shared": "*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "argon2": "^0.41.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.0.0"
  }
}
