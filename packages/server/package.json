{
  "name": "@babelr/server",
  "version": "0.1.0",
  "private": true,
  "license": "Hippocratic-3.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "benchmark": "tsx --env-file=../../.env src/benchmark/cli.ts",
    "seed:i18n": "tsx --env-file=../../.env src/scripts/seed-ui-translations.ts",
    "dump:i18n": "tsx --env-file=../../.env src/scripts/dump-ui-translations.ts"
  },
  "dependencies": {
    "@babelr/plugin-hello": "^0.1.0",
    "@babelr/plugin-polls": "^0.1.0",
    "@babelr/plugin-project-management": "^0.1.0",
    "@babelr/plugin-sdk": "^0.1.0",
    "@babelr/shared": "*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.0",
    "@fastify/websocket": "^11.2.0",
    "argon2": "^0.41.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mediasoup": "^3.19.19",
    "nodemailer": "^8.0.5",
    "openid-client": "^6.8.3",
    "postgres": "^3.4.0",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.0.0"
  }
}
