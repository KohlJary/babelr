# =============================================================================
# Babelr Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database ---
# PostgreSQL connection string.
# Create the database first: createdb babelr
DATABASE_URL=postgresql://babelr:babelr@localhost:5432/babelr

# --- Server ---
# Port the Fastify server listens on.
PORT=3000

# Bind address. Use 0.0.0.0 for all interfaces, 127.0.0.1 for localhost only.
HOST=0.0.0.0

# Public domain for generating ActivityPub URIs.
# In production, set this to your actual domain (e.g., chat.example.com).
BABELR_DOMAIN=localhost:3000

# --- Security ---
# Secret used for signing session cookies. Generate a strong random value:
#   openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# --- Environment ---
# Set to "production" to enable secure cookies (HTTPS required).
NODE_ENV=development

# --- Federation Access Control (optional) ---
# Policy mode: open (default), allowlist, or blocklist.
# FEDERATION_MODE=open

# Comma-separated domain list for allowlist or blocklist mode.
# FEDERATION_DOMAINS=partner.example.com,hq.example.com

# --- SSO (optional) ---
# Set all four to enable OIDC single sign-on.
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://chat.example.com/api/auth/oidc/callback

# --- Translation (optional) ---
# Anthropic API key for the translation benchmark tool.
# Users provide their own keys via the settings UI -- this is only for benchmarking.
# ANTHROPIC_API_KEY=sk-ant-...
